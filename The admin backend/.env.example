NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bullport?schema=Tobi&sslmode=require"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="15m"
CLIENT_REFRESH_DAYS=7
ADMIN_REFRESH_HOURS=8
ADMIN_MFA_REQUIRED=true
CORS_ORIGIN="http://127.0.0.1:8123,http://localhost:8123,http://127.0.0.1:8124,http://localhost:8124,http://127.0.0.1:8125,http://localhost:8125"
DASHBOARD_URL="http://127.0.0.1:8123"
ADMIN_URL="http://127.0.0.1:8124"
PUBLIC_SITE_URL="http://127.0.0.1:8125"
JOB_SECRET="replace-with-a-separate-random-job-secret"
CRON_SECRET="replace-with-the-vercel-cron-secret-if-used"
BLOB_READ_WRITE_TOKEN=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
RESEND_API_KEY=""
RESEND_FROM="BullPort <notifications@example.com>"
SUPPORT_EMAIL="support@bullport.com"
